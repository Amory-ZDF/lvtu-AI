APP_NAME=Lv Backend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_METHODS=GET,POST,PATCH,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_AI=10/minute
RATE_LIMIT_POST=20/minute

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lv_backend
POSTGRES_USER=lv_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

AI_PROVIDER=mock
AI_BASE_URL=
AI_API_KEY=
AI_MODEL_NAME=

AGENT_PROVIDER=mock
AGENT_BASE_URL=
AGENT_API_KEY=
AGENT_WORKFLOW_NAME=

MEDIA_PROVIDER=mock
MEDIA_BASE_URL=https://example.com/assets
MEDIA_PLACEHOLDER_IMAGE_URL=https://example.com/placeholders/default-image.jpg

AI_QUOTA_DAILY_LIMIT=50
AI_CACHE_ENABLED=true
AI_CACHE_TTL=3600

# 高德地图 API（POI 搜索/地理编码/周边搜索）
# 申请地址：https://lbs.amap.com/ → 控制台 → 应用管理 → 创建应用 → 获取 Key
AMAP_API_KEY=
AMAP_BASE_URL=https://restapi.amap.com/v3

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
