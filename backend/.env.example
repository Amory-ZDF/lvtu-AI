APP_NAME=Lv Backend
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_METHODS=GET,POST,PATCH,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID

RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_AI=10/minute

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lv_backend
POSTGRES_USER=lv_user
POSTGRES_PASSWORD=change_me
DATABASE_URL=

# Redis
# 推荐使用 REDIS_URL（优先级高于 HOST/PORT 等字段）
REDIS_URL=redis://localhost:6379/0
# 以下字段仅在未设置 REDIS_URL 时生效
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

AI_PROVIDER=mock
AI_BASE_URL=
AI_API_KEY=
AI_MODEL_NAME=

# AI 生图服务（先留空；生产接入时只放后端 .env，不放前端和 GitHub）
AI_IMAGE_PROVIDER=mock
AI_IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
AI_IMAGE_API_KEY=
AI_IMAGE_MODEL_NAME=
AI_IMAGE_SIZE=2K
AI_IMAGE_WATERMARK=true

AGENT_PROVIDER=mock
AGENT_BASE_URL=
AGENT_API_KEY=
AGENT_WORKFLOW_NAME=

MEDIA_PROVIDER=mock
MEDIA_BASE_URL=https://example.com/assets
MEDIA_PLACEHOLDER_IMAGE_URL=https://example.com/placeholders/default-image.jpg

AI_QUOTA_DAILY_LIMIT=50
AI_CACHE_ENABLED=true
AI_CACHE_TTL=3600

# 数据中台/埋点
ANALYTICS_ENABLED=true
# 生产环境建议配置为你的登录邮箱；多个邮箱用英文逗号分隔
ANALYTICS_ADMIN_EMAILS=

# 高德地图 API（POI 搜索/地理编码/周边搜索）
# 申请地址：https://lbs.amap.com/ → 控制台 → 应用管理 → 创建应用 → 获取 Key
AMAP_API_KEY=
AMAP_BASE_URL=https://restapi.amap.com/v3

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
