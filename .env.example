# =============================================================================
# 旅图项目 Docker Compose 环境变量示例
# 复制为 .env 并修改为生产环境真实值
# =============================================================================

# ---------- PostgreSQL ----------
POSTGRES_DB=lv_backend
POSTGRES_USER=lv_user
POSTGRES_PASSWORD=change_me

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0

# ---------- Backend (FastAPI) ----------
APP_NAME=Lv Backend
APP_ENV=production
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# CORS：生产环境请改为前端实际域名
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_METHODS=GET,POST,PATCH,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-Request-ID

# ---------- 限流 ----------
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=5/minute
RATE_LIMIT_AI=10/minute

# ---------- 数据库连接（容器内会自动指向 postgres 服务）----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=

# ---------- JWT ----------
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- AI 服务 ----------
AI_PROVIDER=mock
AI_BASE_URL=
AI_API_KEY=
AI_MODEL_NAME=

# ---------- Agent 服务 ----------
AGENT_PROVIDER=mock
AGENT_BASE_URL=
AGENT_API_KEY=
AGENT_WORKFLOW_NAME=

# ---------- 媒体服务 ----------
MEDIA_PROVIDER=mock
MEDIA_BASE_URL=https://example.com/assets
MEDIA_PLACEHOLDER_IMAGE_URL=https://example.com/placeholders/default-image.jpg

# ---------- AI 配额与缓存 ----------
AI_QUOTA_DAILY_LIMIT=50
AI_CACHE_ENABLED=true
AI_CACHE_TTL=3600

# ---------- 高德地图 API ----------
AMAP_API_KEY=your_amap_api_key_here
